#!/usr/bin/env bash
# review - the orchestrator's cross-model review step. Runs the reviewer over
# the PR's FINAL SHA + diff + the issue's acceptance criteria, then posts the
# `review` commit status. Green CI is necessary but never sufficient; this is
# the other half of the gate.
#
# The reviewer's tool is generic: --tool picks claude or codex explicitly, or
# it is inferred from --model (same rule as orchestrator/config.py:infer_tool)
# so no role is hardcoded to a specific CLI. If the primary tool cannot run or
# cannot return a verdict, the wrapper falls back to the configured fallback
# model/tool.
#
# If the reviewer's own JSON includes a non-null `advisor_request`, this
# script consults the advisor once (via bin/advise) and re-runs the SAME
# reviewer one more time with the advisor's answer as feedback - one bounded
# round-trip, never a second review pass in the human-visible sense.
#
# Usage: review --pr <pr> [--repo owner/name] [--skill <path>] [--issue <n>]
#               [--model <model>] [--effort max] [--tool codex|claude]
#               [--fallback-model <model>] [--fallback-effort xhigh] [--fallback-tool codex|claude]
#               [--advisor-model <model>] [--advisor-effort high] [--advisor-tool codex|claude]
#               [--dry-run] [--test-verdict approve|request-changes] [--test-routing clean|flagged]
#               [--post]
set -euo pipefail

REPO="anands14/tovi"
SKILL="$(cd "$(dirname "$0")/.." && pwd)/skills/pipeline-reviewer/SKILL.md"
REVIEW_MODEL="${CLAUDE_REVIEW_MODEL:-claude-opus-4-8}"
REVIEW_EFFORT="${CLAUDE_REVIEW_EFFORT:-max}"
REVIEW_TOOL=""
FALLBACK_MODEL="${CODEX_REVIEW_FALLBACK_MODEL:-gpt-5.5}"
FALLBACK_EFFORT="${CODEX_REVIEW_FALLBACK_EFFORT:-xhigh}"
FALLBACK_TOOL=""
ADVISOR_MODEL="" ADVISOR_EFFORT="high" ADVISOR_TOOL=""
PR="" DRY=0 POST=0 VERDICT="" ROUTING="" TEST_VERDICT=0 ISSUE=""
HERE="$(cd "$(dirname "$0")" && pwd)"
ACTIVE_REVIEWER="" ACTIVE_MODEL=""
ADVISOR_CONSULTED=0

while [ $# -gt 0 ]; do
  case "$1" in
    --pr) PR="$2"; shift 2 ;;
    --repo) REPO="$2"; shift 2 ;;
    --skill) SKILL="$2"; shift 2 ;;
    --issue) ISSUE="$2"; shift 2 ;;
    --model) REVIEW_MODEL="$2"; shift 2 ;;
    --effort) REVIEW_EFFORT="$2"; shift 2 ;;
    --tool) REVIEW_TOOL="$2"; shift 2 ;;
    --fallback-model) FALLBACK_MODEL="$2"; shift 2 ;;
    --fallback-effort) FALLBACK_EFFORT="$2"; shift 2 ;;
    --fallback-tool) FALLBACK_TOOL="$2"; shift 2 ;;
    --advisor-model) ADVISOR_MODEL="$2"; shift 2 ;;
    --advisor-effort) ADVISOR_EFFORT="$2"; shift 2 ;;
    --advisor-tool) ADVISOR_TOOL="$2"; shift 2 ;;
    --test-verdict) VERDICT="$2"; TEST_VERDICT=1; shift 2 ;;
    --test-routing) ROUTING="$2"; shift 2 ;;
    --verdict) echo "--verdict was replaced by --test-verdict and cannot post statuses" >&2; exit 2 ;;
    --dry-run) DRY=1; shift ;;
    --post) POST=1; shift ;;
    -h|--help) sed -n '2,20p' "$0"; exit 0 ;;
    *) echo "unknown arg: $1" >&2; exit 2 ;;
  esac
done
[ -n "$PR" ] || { echo "usage: review --pr <pr> [...]" >&2; exit 2; }
if [ "$TEST_VERDICT" = 1 ] && [ "$POST" = 1 ]; then
  echo "--test-verdict may not be combined with --post; use it only for no-status script tests." >&2
  exit 2
fi

# Same tool-inference rule as orchestrator/config.py:infer_tool - a role's CLI
# comes from its model name unless an explicit tool override is given.
infer_tool_from_model() {
  local model_lower
  model_lower="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')"
  case "$model_lower" in
    claude-*|fable-*|mythos-*) echo "claude" ;;
    gpt-*|o1*|o3*) echo "codex" ;;
    gemini-*) echo "gemini" ;;
    *) echo "cannot infer tool for model '$1'; pass a --*-tool override" >&2; exit 2 ;;
  esac
}
[ -n "$REVIEW_TOOL" ] || REVIEW_TOOL="$(infer_tool_from_model "$REVIEW_MODEL")"
[ -n "$FALLBACK_TOOL" ] || FALLBACK_TOOL="$(infer_tool_from_model "$FALLBACK_MODEL")"
[ -n "$ADVISOR_MODEL" ] || ADVISOR_MODEL="$REVIEW_MODEL"
[ -n "$ADVISOR_TOOL" ] || ADVISOR_TOOL="$(infer_tool_from_model "$ADVISOR_MODEL")"

extract_reviewer_field() {
  local field="$1" text="$2" value=""
  value="$(printf '%s' "$text" |
    jq -r --arg field "$field" 'try .[$field] // empty catch empty' 2>/dev/null || true)"
  if [ -n "$value" ]; then
    printf '%s\n' "$value"
    return 0
  fi
  value="$(printf '%s\n' "$text" |
    awk '
      /^```json[[:space:]]*$/ { in_json=1; next }
      /^```[[:space:]]*$/ && in_json { exit }
      in_json { print }
    ' |
    jq -r --arg field "$field" 'try .[$field] // empty catch empty' 2>/dev/null || true)"
  if [ -n "$value" ]; then
    printf '%s\n' "$value"
    return 0
  fi
  printf '%s\n' "$text" |
    grep -Eo "\"$field\"[[:space:]]*:[[:space:]]*\"[^\"]+\"" |
    head -1 |
    sed -E 's/^[^:]+:[[:space:]]*"([^"]+)".*$/\1/'
}

extract_reviewer_object() {
  local field="$1" text="$2"
  printf '%s' "$text" | jq -c --arg field "$field" 'try .[$field] catch null' 2>/dev/null || true
}

# Review inputs: the FINAL head SHA (Q2 - always re-review the exact SHA), the
# diff, and the PR body (which carries the criteria-coverage + the implementer's
# notes per the PR template). The linked issue's acceptance criteria are the
# oracle; the PR body is implementer-controlled and is context only.
head_sha="$(gh pr view "$PR" -R "$REPO" --json headRefOid -q .headRefOid)"
diff="$(gh pr diff "$PR" -R "$REPO")"
body="$(gh pr view "$PR" -R "$REPO" --json body -q .body)"
if [ -z "$ISSUE" ]; then
  ISSUE="$(gh pr view "$PR" -R "$REPO" --json closingIssuesReferences -q '.closingIssuesReferences[0].number // empty' 2>/dev/null || true)"
fi
if [ -z "$ISSUE" ]; then
  ISSUE="$(printf '%s\n' "$body" | grep -oiE '(close[sd]?|fix(e[sd])?|resolve[sd]?) #[0-9]+' | head -1 | grep -oE '[0-9]+' || true)"
fi
[ -n "$ISSUE" ] || {
  echo "no linked issue found; review needs the issue acceptance criteria as the oracle" >&2
  exit 3
}
issue_json="$(gh issue view "$ISSUE" -R "$REPO" --json number,title,body)"
issue_title="$(printf '%s\n' "$issue_json" | jq -r .title)"
issue_body="$(printf '%s\n' "$issue_json" | jq -r .body)"

# Condensed from CONSTITUTION.md so the reviewer does not need a full re-read
# (or a re-read of the project's AGENTS.md/CLAUDE.md) on every invocation -
# this runs from the framework repo's cwd, so those files are not auto-loaded
# the way they would be for a `claude -p` run inside the target checkout.
reviewer_invariants="$(cat <<'EOF'
## Standing invariants (condensed; do not assume the full constitution was auto-loaded)

- Only a human merges to the default branch; you approve or request changes, you never merge.
- Tests must come from the acceptance criteria, not invented by the implementer to match its own code; flag any test that was weakened, skipped, or deleted.
- A user-facing change needs E2E at its declared level run on a credible real target, or a loud, named e2e-exempt reason - never a silent default.
- No agent may edit a protected path (this constitution, CI/gate config, branch-protection config, the project constitution) without declared, justified risk.
- Conventions may be deviated from, but only loudly - declared and reasoned in the PR. Silent deviation is the one forbidden thing.
- Route every approval as clean (glance-review candidate) or flagged (protected-path/test-discipline override, deviation, architecture tradeoff, UX uncertainty, suspicious test, or stuck history - needs real human attention).
- Stuck or unsure and it is not a human-only call? set advisor_request: {question, context} instead of guessing - you get one answer, then decide.
EOF
)"

base_prompt="$(cat "$SKILL" 2>/dev/null || echo '[pipeline-reviewer role skill]')

$reviewer_invariants

Review this PR on its FINAL SHA ($head_sha). Green CI is necessary, not
sufficient. Judge any test-assertion change against the acceptance criteria,
never your own taste; if the criteria do not settle it, request human input.
Emit only the structured JSON object from your output contract.
Do not wrap it in Markdown.

--- linked issue #$ISSUE: $issue_title ---
$issue_body

--- PR body ---
$body

--- diff ---
$diff"
prompt="$base_prompt"

if [ "$DRY" = 1 ]; then
  echo "Would review PR #$PR @ $head_sha via $REVIEW_TOOL model $REVIEW_MODEL/$REVIEW_EFFORT."
  echo "Fallback reviewer: $FALLBACK_TOOL model $FALLBACK_MODEL/$FALLBACK_EFFORT."
  echo "Advisor (on request): $ADVISOR_TOOL model $ADVISOR_MODEL/$ADVISOR_EFFORT."
  echo "Prompt assembled: ${#prompt} bytes (skill + final-SHA instruction + issue + body + diff)."
  exit 0
fi

parse_reviewer_payload() {
  local text="$1"
  local payload="$2"
  VERDICT="$(extract_reviewer_field verdict "$payload")"
  ROUTING="$(extract_reviewer_field routing "$payload")"
  ADVISOR_REQUEST="$(extract_reviewer_object advisor_request "$payload")"
  if [ -z "$VERDICT" ] && [ -n "$payload" ]; then
    VERDICT="$payload"
  fi
  if [ -z "$VERDICT" ]; then
    VERDICT="$(extract_reviewer_field verdict "$text")"
  fi
  if [ -z "$ROUTING" ]; then
    ROUTING="$(extract_reviewer_field routing "$text")"
  fi
  if [ -z "$ADVISOR_REQUEST" ] || [ "$ADVISOR_REQUEST" = "null" ]; then
    ADVISOR_REQUEST="$(extract_reviewer_object advisor_request "$text")"
  fi
}

review_payload_is_usable() {
  case "$VERDICT" in
    approve|request-changes|request_changes|changes) ;;
    *) return 1 ;;
  esac
  case "$ROUTING" in
    clean|flagged) ;;
    *) return 1 ;;
  esac
}

run_claude_reviewer() {
  local model="$1" effort="$2"
  local out reviewer_payload err_file
  command -v claude >/dev/null || {
    echo "claude not on PATH" >&2
    return 1
  }
  err_file="$(mktemp "${TMPDIR:-/tmp}/review-claude.XXXXXX")"
  if ! out="$(printf '%s' "$prompt" | claude -p --model "$model" --effort "$effort" --output-format json 2>"$err_file")"; then
    echo "claude reviewer failed" >&2
    cat "$err_file" >&2 || true
    rm -f "$err_file"
    return 1
  fi
  rm -f "$err_file"
  reviewer_payload="$(printf '%s' "$out" | jq -r '.verdict // .result // empty')"
  parse_reviewer_payload "$out" "$reviewer_payload"
  review_payload_is_usable
}

run_codex_reviewer() {
  local model="$1" effort="$2"
  local result_file stdout_file reviewer_payload
  command -v codex >/dev/null || {
    echo "codex not on PATH" >&2
    return 1
  }
  result_file="$(mktemp "${TMPDIR:-/tmp}/review-codex-result.XXXXXX")"
  stdout_file="$(mktemp "${TMPDIR:-/tmp}/review-codex-stdout.XXXXXX")"
  if ! printf '%s' "$prompt" | codex exec \
    --model "$model" \
    -c "model_reasoning_effort=\"$effort\"" \
    --json \
    --output-last-message "$result_file" \
    - >"$stdout_file"; then
    cat "$stdout_file" >&2 || true
    rm -f "$result_file" "$stdout_file"
    echo "codex reviewer failed" >&2
    return 1
  fi
  reviewer_payload="$(cat "$result_file")"
  parse_reviewer_payload "$reviewer_payload" "$reviewer_payload"
  rm -f "$result_file" "$stdout_file"
  review_payload_is_usable
}

# Generic dispatch: run whichever tool a model resolves to. Extend here if a
# third CLI is ever added.
run_reviewer_tool() {
  local tool="$1" model="$2" effort="$3"
  case "$tool" in
    claude) run_claude_reviewer "$model" "$effort" ;;
    codex) run_codex_reviewer "$model" "$effort" ;;
    *) echo "unsupported reviewer tool: $tool" >&2; return 1 ;;
  esac
}

run_reviewer_with_fallback() {
  ADVISOR_REQUEST=""
  if run_reviewer_tool "$REVIEW_TOOL" "$REVIEW_MODEL" "$REVIEW_EFFORT"; then
    ACTIVE_REVIEWER="$REVIEW_TOOL"; ACTIVE_MODEL="$REVIEW_MODEL/$REVIEW_EFFORT"
    return 0
  fi
  echo "primary reviewer ($REVIEW_TOOL) unusable; falling back to $FALLBACK_TOOL" >&2
  if run_reviewer_tool "$FALLBACK_TOOL" "$FALLBACK_MODEL" "$FALLBACK_EFFORT"; then
    ACTIVE_REVIEWER="$FALLBACK_TOOL"; ACTIVE_MODEL="$FALLBACK_MODEL/$FALLBACK_EFFORT"
    return 0
  fi
  echo "fallback reviewer ($FALLBACK_TOOL) also unusable" >&2
  return 1
}

consult_advisor_and_retry() {
  local question context context_file answer
  question="$(printf '%s' "$ADVISOR_REQUEST" | jq -r '.question // "reviewer needs help"' 2>/dev/null || echo "reviewer needs help")"
  context="$(printf '%s' "$ADVISOR_REQUEST" | jq -r '.context // ""' 2>/dev/null || echo "")"
  context_file="$(mktemp "${TMPDIR:-/tmp}/review-advisor-context.XXXXXX")"
  printf '%s' "$context" >"$context_file"
  echo "reviewer asked the advisor: $question" >&2
  if ! answer="$("$HERE/advise" --question "$question" --context-file "$context_file" \
      --model "$ADVISOR_MODEL" --effort "$ADVISOR_EFFORT" --tool "$ADVISOR_TOOL")"; then
    rm -f "$context_file"
    echo "advisor consult failed; proceeding with the reviewer's own answer" >&2
    return 1
  fi
  rm -f "$context_file"
  prompt="$base_prompt

--- feedback: advisor consult ---
You asked: $question
Advisor answered: $answer
Do not ask again this turn; give your final verdict now."
  ADVISOR_CONSULTED=1
  run_reviewer_tool "$ACTIVE_REVIEWER" "$REVIEW_MODEL" "$REVIEW_EFFORT"
}

# Run the reviewer unless a verdict was supplied for testing.
if [ -z "$VERDICT" ]; then
  run_reviewer_with_fallback
  if [ -n "${ADVISOR_REQUEST:-}" ] && [ "$ADVISOR_REQUEST" != "null" ] && [ "$ADVISOR_CONSULTED" = 0 ]; then
    consult_advisor_and_retry || true
  fi
fi

case "$VERDICT" in
  approve) state=success ;;
  request-changes|request_changes|changes) state=failure ;;
  *) echo "unrecognized verdict: '$VERDICT'" >&2; exit 3 ;;
esac
if [ "$TEST_VERDICT" = 1 ] && [ -z "$ROUTING" ]; then
  ROUTING=clean
fi
case "$ROUTING" in
  clean|flagged) ;;
  *) echo "unrecognized routing: '$ROUTING' (expected clean or flagged)" >&2; exit 3 ;;
esac
if [ -n "$ROUTING" ]; then
  echo "review verdict: $VERDICT/$ROUTING -> $state  (reviewer $ACTIVE_REVIEWER, model $ACTIVE_MODEL, sha $head_sha)"
else
  echo "review verdict: $VERDICT -> $state  (reviewer $ACTIVE_REVIEWER, model $ACTIVE_MODEL, sha $head_sha)"
fi

if [ "$POST" = 1 ]; then
  current_sha="$(gh pr view "$PR" -R "$REPO" --json headRefOid -q .headRefOid)"
  if [ "$current_sha" != "$head_sha" ]; then
    echo "PR head changed during review ($head_sha -> $current_sha); refusing to post stale review." >&2
    exit 4
  fi
  desc="cross-model review: $VERDICT"
  [ -n "$ROUTING" ] && desc="$desc/$ROUTING"
  desc="$desc; $ACTIVE_REVIEWER $ACTIVE_MODEL"
  "$HERE/post-status" --sha "$head_sha" --context review --state "$state" \
    --description "$desc" --repo "$REPO"
fi

#!/usr/bin/env bash
# sim-validate - the orchestrator's pre-PR sim-validation step. Picks the
# platform from the diff (macOS by default; iOS when the change can touch iOS
# surfaces), runs the UI e2e on that device, and posts the `sim-validation`
# commit status through post-status. Only the orchestrator runs this.
#
# Usage: sim-validate --sha <sha>|--pr <pr> [--base <ref>]
#          [--platform macos|ios|both] [--dry-run] [--post]
#          [--repo owner/name] [--app-dir <path>] [--config <path>]
set -euo pipefail

REPO=""
APP_DIR=""
BASE="origin/main"
SHA="" PR="" PLATFORM="" DRY=0 POST=0
HERE="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$HERE/.." && pwd)"
PROJECT_CONFIG="$ROOT/projects/humanmind.yaml"
WORKTREE=""
TARGET_SHA=""

while [ $# -gt 0 ]; do
  case "$1" in
    --sha) SHA="$2"; shift 2 ;;
    --pr) PR="$2"; shift 2 ;;
    --base) BASE="$2"; shift 2 ;;
    --platform) PLATFORM="$2"; shift 2 ;;
    --dry-run) DRY=1; shift ;;
    --post) POST=1; shift ;;
    --repo) REPO="$2"; shift 2 ;;
    --app-dir) APP_DIR="$2"; shift 2 ;;
    --config) PROJECT_CONFIG="$2"; shift 2 ;;
    -h|--help) sed -n '2,9p' "$0"; exit 0 ;;
    *) echo "unknown arg: $1" >&2; exit 2 ;;
  esac
done
if [ -n "$PLATFORM" ]; then
  case "$PLATFORM" in
    macos|ios|both) ;;
    *) echo "unknown platform: $PLATFORM" >&2; exit 2 ;;
  esac
fi

cleanup() {
  if [ -n "${WORKTREE:-}" ] && [ -d "$WORKTREE" ]; then
    git -C "$APP_DIR" worktree remove -f "$WORKTREE" >/dev/null 2>&1 || true
  fi
}
trap cleanup EXIT

config_scalar() {
  local key="$1" default="$2"
  [ -f "$PROJECT_CONFIG" ] || { printf '%s\n' "$default"; return; }
  awk -v key="$key" '
    $0 ~ "^[[:space:]]{2}" key ":" {
      sub("^[^:]+:[[:space:]]*", "")
      gsub(/^["'\'']|["'\'']$/, "")
      print
      found=1
      exit
    }
    END { if (!found) exit 1 }
  ' "$PROJECT_CONFIG" 2>/dev/null || printf '%s\n' "$default"
}

config_list() {
  local key="$1"
  [ -f "$PROJECT_CONFIG" ] || return 0
  awk -v key="$key" '
    $0 ~ "^[[:space:]]{2}" key ":" { in_list=1; next }
    in_list && $0 ~ "^[[:space:]]{2}[A-Za-z0-9_-]+:" { exit }
    in_list && $0 ~ "^[[:space:]]*-" {
      sub("^[[:space:]]*-[[:space:]]*", "")
      gsub(/^["'\'']|["'\'']$/, "")
      print
    }
  ' "$PROJECT_CONFIG"
}

matches_any() {
  local text="$1" patterns="$2" pat
  [ -n "$patterns" ] || return 1
  while IFS= read -r pat; do
    [ -n "$pat" ] || continue
    if printf '%s\n' "$text" | grep -Eq "$pat"; then
      return 0
    fi
  done <<<"$patterns"
  return 1
}

all_changed_paths_match() {
  local text="$1" patterns="$2" file pat matched
  [ -n "$text" ] || return 1
  [ -n "$patterns" ] || return 1
  while IFS= read -r file; do
    [ -n "$file" ] || continue
    matched=0
    while IFS= read -r pat; do
      [ -n "$pat" ] || continue
      if printf '%s\n' "$file" | grep -Eq "$pat"; then
        matched=1
        break
      fi
    done <<<"$patterns"
    [ "$matched" = 1 ] || return 1
  done <<<"$text"
  return 0
}

changed_content_matches() {
  local patterns="$1" file pat
  [ -n "$patterns" ] || return 1
  while IFS= read -r file; do
    [ -n "$file" ] || continue
    [ -f "$WORKTREE/$file" ] || continue
    while IFS= read -r pat; do
      [ -n "$pat" ] || continue
      if grep -Eq "$pat" "$WORKTREE/$file"; then
        return 0
      fi
    done <<<"$patterns"
  done <<<"$changed"
  return 1
}

resolve_app_dir() {
  local dir="$1"
  case "$dir" in
    "~"|"~/") dir="$HOME" ;;
    "~/"*) dir="$HOME/${dir#"~/"}" ;;
    /*) ;;
    *) dir="$ROOT/$dir" ;;
  esac
  cd "$dir" && pwd
}

REPO="${REPO:-$(config_scalar repo "")}"
APP_DIR="${APP_DIR:-$(config_scalar local_path "")}"
[ -n "$REPO" ] || { echo "missing repo; pass --repo or set project.repo in $PROJECT_CONFIG" >&2; exit 2; }
[ -n "$APP_DIR" ] || { echo "missing app dir; pass --app-dir or set project.local_path in $PROJECT_CONFIG" >&2; exit 2; }
APP_DIR="$(resolve_app_dir "$APP_DIR")"
[ -d "$APP_DIR/.git" ] || { echo "app dir is not a git checkout: $APP_DIR" >&2; exit 2; }

cd "$APP_DIR"
git fetch origin -q

# Head ref to diff and validate.
if [ -n "$PR" ]; then
  TARGET_SHA="$(gh pr view "$PR" -R "$REPO" --json headRefOid -q .headRefOid)"
  git fetch origin -q "+refs/pull/${PR}/head:refs/remotes/origin/pr/${PR}"
  fetched_sha="$(git rev-parse "refs/remotes/origin/pr/${PR}^{commit}")"
  if [ "$fetched_sha" != "$TARGET_SHA" ]; then
    echo "PR #$PR moved while fetching ($TARGET_SHA -> $fetched_sha); retry." >&2
    exit 1
  fi
else
  TARGET_SHA="${SHA:-$(git rev-parse HEAD)}"
  git cat-file -e "$TARGET_SHA^{commit}" 2>/dev/null || {
    echo "target SHA '$TARGET_SHA' is not present locally; pass --pr or fetch it first." >&2
    exit 2
  }
fi
TARGET_SHA="$(git rev-parse "$TARGET_SHA^{commit}")"

WORKTREE="$(mktemp -d "${TMPDIR:-/tmp}/tovi-sim.XXXXXX")"
rmdir "$WORKTREE"
git worktree add --detach "$WORKTREE" "$TARGET_SHA" >/dev/null
actual_sha="$(git -C "$WORKTREE" rev-parse HEAD)"
if [ "$actual_sha" != "$TARGET_SHA" ]; then
  echo "worktree checkout mismatch ($actual_sha != $TARGET_SHA)" >&2
  exit 1
fi

# Change-aware platform selection from project-configured path and content rules.
if [ -z "$PLATFORM" ]; then
  if changed="$(git diff --name-only "$BASE...$TARGET_SHA" 2>/dev/null)"; then
    na_path_allowlist="$(config_list allow_na_when_all_paths_match)"
    if all_changed_paths_match "$changed" "$na_path_allowlist"; then
      state=success
      desc="sim-validation N/A under project rules"
      echo "sim-validation platform(s): N/A  (sha: $TARGET_SHA)"
      echo "sim-validation: $state ($desc)"
      if [ "$POST" = 1 ]; then
        "$HERE/post-status" --sha "$TARGET_SHA" --context sim-validation \
          --state "$state" --description "$desc" --repo "$REPO"
      fi
      exit 0
    fi
    default_platform="$(config_scalar default_platform macos)"
    ios_path_triggers="$(config_list ios_path_triggers)"
    both_path_triggers="$(config_list both_path_triggers)"
    ios_content_triggers="$(config_list ios_content_triggers)"
    if matches_any "$changed" "$both_path_triggers"; then
      PLATFORM="both"
    elif matches_any "$changed" "$ios_path_triggers" || changed_content_matches "$ios_content_triggers"; then
      PLATFORM="ios"
    else
      PLATFORM="$default_platform"
    fi
  else
    echo "could not diff $BASE...$TARGET_SHA; failing closed by validating both local targets." >&2
    changed=""
    PLATFORM="both"
  fi
fi
case "$PLATFORM" in
  macos|ios|both) ;;
  *) echo "unknown platform: $PLATFORM" >&2; exit 2 ;;
esac
[ "$PLATFORM" = "both" ] && PLATFORMS="macos ios" || PLATFORMS="$PLATFORM"
echo "sim-validation platform(s): $PLATFORMS  (sha: $TARGET_SHA)"

if [ "$DRY" = 1 ]; then
  echo "DRY RUN: would run the e2e on [$PLATFORMS] and post sim-validation."
  exit 0
fi

# Run the e2e on each chosen platform.
ok=1
infra=0
for plat in $PLATFORMS; do
  case "$plat" in
    ios)
      dev="$(xcrun simctl list devices booted 2>/dev/null | grep -oiE '[0-9a-f-]{36}' | head -1 || true)"
      [ -n "$dev" ] || { echo "no booted iOS simulator (boot one, or use --platform macos)"; ok=0; infra=1; break; }
      ;;
    macos) dev="macos" ;;
    *) echo "unknown platform: $plat" >&2; exit 2 ;;
  esac
  echo "== e2e on $plat ($dev) =="
  ( cd "$WORKTREE/packages/tovi_app" && fvm flutter test integration_test --tags e2e -d "$dev" ) || { ok=0; break; }
done

if [ "$ok" = 1 ]; then
  state=success
elif [ "$infra" = 1 ]; then
  state=error
else
  state=failure
fi
echo "sim-validation: $state"

if [ "$POST" = 1 ]; then
  desc="sim-validation $state on [$PLATFORMS]"
  "$HERE/post-status" --sha "$TARGET_SHA" --context sim-validation --state "$state" --description "$desc" --repo "$REPO"
fi

[ "$ok" = 1 ]
